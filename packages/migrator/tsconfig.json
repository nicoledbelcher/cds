{
  "extends": "../../tsconfig.project.json",
  "compilerOptions": {
    "declarationDir": "dts",
    "rootDir": "src"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    // Keep migrator package typecheck focused on implementation source only.
    // Transform fixtures intentionally contain example app code patterns that
    // are validated by Jest transform tests, not by tsc project compilation.
    "**/__tests__/**",
    "**/__fixtures__/**",
    "**/*.test.*",
    "**/*.spec.*"
  ],
  "references": []
}
