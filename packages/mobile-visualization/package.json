{
  "name": "@coinbase/cds-mobile-visualization",
  "version": "3.4.0-beta.13",
  "description": "Coinbase Design System - Mobile Visualization Native",
  "repository": {
    "type": "git",
    "url": "git@github.com:coinbase/cds.git",
    "directory": "packages/mobile-visualization"
  },
  "type": "module",
  "main": "./esm/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "default": "./esm/index.js"
    },
    "./chart": {
      "types": "./dts/chart/index.d.ts",
      "default": "./esm/chart/index.js"
    },
    "./sparkline": {
      "types": "./dts/sparkline/index.d.ts",
      "default": "./esm/sparkline/index.js"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./esm/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dts",
    "esm",
    "CHANGELOG"
  ],
  "peerDependencies": {
    "@coinbase/cds-common": "workspace:^",
    "@coinbase/cds-lottie-files": "workspace:^",
    "@coinbase/cds-mobile": "workspace:^",
    "@coinbase/cds-utils": "workspace:^",
    "@shopify/react-native-skia": "2.2.12",
    "react": "~19.1.2",
    "react-native": "~0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.2"
  },
  "dependencies": {
    "d3-interpolate-path": "^2.3.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.27.1",
    "@coinbase/cds-common": "workspace:^",
    "@coinbase/cds-lottie-files": "workspace:^",
    "@coinbase/cds-mobile": "workspace:^",
    "@coinbase/cds-utils": "workspace:^",
    "@shopify/react-native-skia": "2.2.12",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "19.1.2",
    "react": "19.1.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.2",
    "react-test-renderer": "19.1.2"
  }
}
