{
  "import": "import { Button } from '@coinbase/cds-web/buttons/Button'",
  "source": "https://github.com/coinbase/cds/blob/master/packages/web/src/buttons/Button.tsx",
  "storybook": "https://cds-storybook.coinbase.com/?path=/story/components-buttons-button--create-button-stories",
  "figma": "https://www.figma.com/design/k5CtyJccNQUGMI5bI4lJ2g/%E2%9C%A8-CDS-Components?m=auto&node-id=50-618&t=04zdd4GyupBRPqUz-1",
  "description": "A pressable button element.",
  "relatedComponents": [
    {
      "label": "Pressable",
      "url": "/components/inputs/Pressable/"
    },
    {
      "label": "ButtonGroup",
      "url": "/components/layout/ButtonGroup/"
    },
    {
      "label": "IconButton",
      "url": "/components/inputs/IconButton/"
    }
  ],
  "dependencies": [],
  "stylesAPI": {
    "staticClassName": "cds-Button",
    "selectors": [
      {
        "name": "root",
        "staticClassName": "cds-Button",
        "description": "Root button element"
      }
    ],
    "dataAttributes": [
      {
        "attribute": "data-variant",
        "selector": "root",
        "condition": "Always set",
        "values": "primary | secondary | tertiary | negative"
      },
      {
        "attribute": "data-block",
        "selector": "root",
        "condition": "block prop is true"
      },
      {
        "attribute": "data-compact",
        "selector": "root",
        "condition": "compact prop is true"
      },
      {
        "attribute": "data-transparent",
        "selector": "root",
        "condition": "transparent prop is true"
      },
      {
        "attribute": "data-flush",
        "selector": "root",
        "condition": "flush prop is set",
        "values": "start | end"
      },
      {
        "attribute": "data-loading",
        "selector": "root",
        "condition": "loading prop is true"
      },
      {
        "attribute": "data-active",
        "selector": "root",
        "condition": "Button is being pressed"
      },
      {
        "attribute": "data-disabled",
        "selector": "root",
        "condition": "disabled prop is true"
      }
    ]
  }
