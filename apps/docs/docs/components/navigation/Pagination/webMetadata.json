{
  "import": "import { Pagination } from '@coinbase/cds-web/pagination/Pagination'",
  "source": "https://github.com/coinbase/cds/blob/master/packages/web/src/pagination/Pagination.tsx",
  "storybook": "https://cds-storybook.coinbase.com/?path=/story/components-pagination--pagination-examples",
  "figma": "https://www.figma.com/design/k5CtyJccNQUGMI5bI4lJ2g/%E2%9C%A8-CDS-Components?m=auto&node-id=49607-6712&t=VzGX5hnRKveOrhnl-1",
  "description": "Pagination is used to navigate through a list of items.",
  "relatedComponents": [
    {
      "label": "NavigationBar",
      "url": "/components/navigation/NavigationBar/"
    },
    {
      "label": "Button",
      "url": "/components/inputs/Button/"
    },
    {
      "label": "IconButton",
      "url": "/components/inputs/IconButton/"
    },
    {
      "label": "Table",
      "url": "/components/data-display/Table/"
    }
  ],
  "dependencies": [],
  "stylesAPI": {
    "staticClassName": "cds-Pagination",
    "selectors": [
      {
        "name": "root",
        "staticClassName": "cds-Pagination",
        "description": "Root navigation element"
      },
      {
        "name": "navigationButton",
        "staticClassName": "cds-Pagination-navigationButton",
        "description": "First/previous/next/last navigation buttons"
      },
      {
        "name": "pageButton",
        "staticClassName": "cds-Pagination-pageButton",
        "description": "Page number buttons"
      },
      {
        "name": "ellipsis",
        "staticClassName": "cds-Pagination-ellipsis",
        "description": "Ellipsis between page ranges"
      }
    ],
    "dataAttributes": [
      {
        "attribute": "data-disabled",
        "selector": "root",
        "condition": "disabled prop is true",
        "values": "true"
      },
      {
        "attribute": "data-show-first-last-buttons",
        "selector": "root",
        "condition": "showFirstLastButtons prop is true",
        "values": "true"
      },
      {
        "attribute": "data-direction",
        "selector": "navigationButton",
        "condition": "always",
        "values": "first | previous | next | last"
      },
      {
        "attribute": "data-pagenumber",
        "selector": "pageButton",
        "condition": "always",
        "values": "number"
      },
      {
        "attribute": "data-current",
        "selector": "pageButton",
        "condition": "isCurrentPage is true",
        "values": "true"
      },
      {
        "attribute": "data-ellipsis",
        "selector": "ellipsis",
        "condition": "always",
        "values": "true"
      }
    ]
  }
}
